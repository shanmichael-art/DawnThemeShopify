{% comment %}
  Renders the "buy direct" value stack — total cost here vs. the marketplace,
  plus the live delivery estimate.

  Accepts:
  - product: {Object} Product liquid object
  - block:   {Object} The value_stack block (settings drive all rates)

  All money math is done in cents, the way Shopify stores prices.

  The marketplace comparison only renders when compare_at_price is set AND
  higher than price. Set compare_at_price to the marketplace list price for
  the comparison to be accurate.
{% endcomment %}

{%- liquid
  assign s = block.settings

  assign direct_ship = s.direct_shipping | times: 100
  assign tier = s.marketplace_tier | times: 100
  assign mkt_ship_under = s.marketplace_ship_under | times: 100
  assign mkt_ship_over = s.marketplace_ship_over | times: 100

  assign variant = product.selected_or_first_available_variant
  assign price = variant.price | default: product.price
  assign mkt_price = variant.compare_at_price
  if mkt_price == blank
    assign mkt_price = product.compare_at_price
  endif

  assign has_comparison = false
  if s.show_comparison and mkt_price != blank and mkt_price > price
    assign has_comparison = true
  endif

  if mkt_price > tier
    assign mkt_ship = mkt_ship_over
  else
    assign mkt_ship = mkt_ship_under
  endif

  assign direct_total = price | plus: direct_ship
  assign mkt_total = mkt_price | plus: mkt_ship
  assign savings = mkt_total | minus: direct_total

  comment
    Tax estimate is based on the item price only, not the marketplace total —
    it understates slightly, which is the safe direction. Falls back to our own
    price when there is no compare-at price, otherwise it would render as $0.
  endcomment
  assign tax_base = mkt_price
  if tax_base == blank or tax_base < price
    assign tax_base = price
  endif

  comment
    Rounded to the nearest $10 so the range reads as an estimate rather than
    false precision. (+500 before the integer divide rounds instead of floors.)
  endcomment
  assign tax_low = tax_base | times: s.tax_rate_low | divided_by: 100 | plus: 500 | divided_by: 1000 | times: 1000
  assign tax_high = tax_base | times: s.tax_rate_high | divided_by: 100 | plus: 500 | divided_by: 1000 | times: 1000

  assign save_low = savings | plus: tax_low
  assign save_high = savings | plus: tax_high
-%}

<div class="aeonic-vs" {{ block.shopify_attributes }}>
  <span class="aeonic-vs__eyebrow">{{ s.heading }}</span>

  <dl class="aeonic-vs__lines">
    <div class="aeonic-vs__line">
      <dt>This guitar</dt>
      <dd>{{ price | money }}</dd>
    </div>
    <div class="aeonic-vs__line">
      <dt>Insured shipping{% if s.shipping_note != blank %} <span class="aeonic-vs__hint">{{ s.shipping_note }}</span>{% endif %}</dt>
      <dd>{{ direct_ship | money }}</dd>
    </div>
    <div class="aeonic-vs__line">
      <dt>Sales tax <span class="aeonic-vs__hint">outside {{ s.home_state }}</span></dt>
      <dd class="aeonic-vs__free">None</dd>
    </div>
    <div class="aeonic-vs__line aeonic-vs__line--total">
      <dt>Your total</dt>
      <dd>{{ direct_total | money }}</dd>
    </div>
  </dl>

  {%- if s.show_delivery -%}
    {%- assign delivery_days = s.delivery_days | default: 3 -%}
    <p class="aeonic-vs__delivery">
      <svg class="aeonic-vs__delivery-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="1" y="3" width="10" height="9" rx="1"/>
        <path d="M11 6h2l2 3v3h-4V6z"/>
        <circle cx="4" cy="13.5" r="1.5"/>
        <circle cx="13" cy="13.5" r="1.5"/>
      </svg>
      <span>
        Arrives as early as
        <strong
          data-aeonic-delivery-date
          data-aeonic-delivery-days="{{ delivery_days }}"
        >{{ delivery_days }} business days</strong>
      </span>
    </p>
  {%- endif -%}

  {%- if has_comparison -%}
    <div class="aeonic-vs__compare">
      <p class="aeonic-vs__compare-row">
        <span>Same guitar on {{ s.marketplace_name }}</span>
        <span class="aeonic-vs__compare-price">{{ mkt_total | money }}</span>
      </p>
      <p class="aeonic-vs__compare-note">
        {{ mkt_price | money }} + {{ mkt_ship | money }} shipping{% if s.show_tax_estimate %}, plus {{ tax_low | money_without_trailing_zeros }}–{{ tax_high | money_without_trailing_zeros }} sales tax in most states{% endif %}
      </p>
    </div>

    {%- if savings > 0 -%}
      <p class="aeonic-vs__savings">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="2 8.5 6 12.5 14 4"/>
        </svg>
        {%- if s.show_tax_estimate -%}
          <span>
            You save <strong>{{ save_low | money_without_trailing_zeros }}–{{ save_high | money_without_trailing_zeros }}</strong> buying direct.<sup>*</sup>
          </span>
        {%- else -%}
          <span>
            You save <strong>{{ savings | money }}</strong> buying direct.
          </span>
        {%- endif -%}
      </p>
    {%- endif -%}
  {%- elsif s.show_tax_estimate -%}
    <p class="aeonic-vs__savings">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="2 8.5 6 12.5 14 4"/>
      </svg>
      <span>
        Buying here skips the sales tax the marketplaces collect — roughly
        <strong>{{ tax_low | money_without_trailing_zeros }}–{{ tax_high | money_without_trailing_zeros }}</strong> on a guitar at this price.<sup>*</sup>
      </span>
    </p>
  {%- endif -%}

  {%- if s.show_tax_estimate and s.footnote != blank -%}
    <p class="aeonic-vs__footnote">{{ s.footnote }}</p>
  {%- endif -%}
</div>

{%- if s.show_delivery -%}
  <script>
    (function () {
      // The markup ships with a readable fallback ("3 business days") already in
      // place, so this only ever upgrades it to a real date. Dawn re-renders the
      // product-info container via innerHTML on variant change, which both wipes
      // this script's work and prevents it re-running — hence the repaint hooks.
      function paint() {
        var els = document.querySelectorAll('[data-aeonic-delivery-date]');
        for (var i = 0; i < els.length; i++) {
          var el = els[i];
          if (el.getAttribute('data-aeonic-delivery-painted')) continue;

          var days = parseInt(el.getAttribute('data-aeonic-delivery-days'), 10);
          if (!days || days < 0) days = 3;

          var d = new Date();
          var added = 0;
          while (added < days) {
            d.setDate(d.getDate() + 1);
            var wd = d.getDay();
            if (wd !== 0 && wd !== 6) added++;
          }

          el.textContent = d.toLocaleDateString('en-US', {
            weekday: 'long',
            month: 'long',
            day: 'numeric'
          });
          el.setAttribute('data-aeonic-delivery-painted', '1');
        }
      }

      paint();
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', paint);
      }
      document.addEventListener('shopify:section:load', paint);
      setTimeout(paint, 400);
    })();
  </script>
{%- endif -%}

{%- style -%}
  .aeonic-vs {
    margin: 1.6rem 0;
    padding: 1.6rem 1.8rem;
    border: 1px solid rgba(var(--color-foreground), 0.12);
    border-radius: 8px;
    background: rgba(var(--color-foreground), 0.02);
  }

  .aeonic-vs__eyebrow {
    display: block;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #e7cc87;
    margin-bottom: 1.2rem;
  }

  .aeonic-vs__lines {
    margin: 0;
    padding: 0;
  }

  .aeonic-vs__line {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.2rem;
    padding: 0.45rem 0;
  }

  .aeonic-vs__line dt,
  .aeonic-vs__line dd {
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.4;
    color: rgba(var(--color-foreground), 0.72);
  }

  .aeonic-vs__line dd {
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .aeonic-vs__hint {
    font-size: 1.15rem;
    color: rgba(var(--color-foreground), 0.45);
  }

  .aeonic-vs__free {
    color: #2ea04d !important;
    font-weight: 600;
  }

  .aeonic-vs__line--total {
    margin-top: 0.6rem;
    padding-top: 0.9rem;
    border-top: 1px solid rgba(var(--color-foreground), 0.12);
  }

  .aeonic-vs__line--total dt,
  .aeonic-vs__line--total dd {
    font-size: 1.6rem;
    font-weight: 700;
    color: rgb(var(--color-foreground));
  }

  .aeonic-vs__delivery {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1.2rem 0 0;
    padding: 1rem 1.2rem;
    border-radius: 6px;
    background: rgba(231, 204, 135, 0.1);
    border: 1px solid rgba(231, 204, 135, 0.3);
    font-size: 1.35rem;
    line-height: 1.4;
    color: rgba(var(--color-foreground), 0.7);
  }

  .aeonic-vs__delivery strong {
    font-weight: 700;
    color: rgb(var(--color-foreground));
    white-space: nowrap;
  }

  .aeonic-vs__delivery-icon {
    width: 17px;
    height: 17px;
    flex-shrink: 0;
    color: #e7cc87;
  }

  .aeonic-vs__compare {
    margin-top: 1.4rem;
    padding-top: 1.2rem;
    border-top: 1px dashed rgba(var(--color-foreground), 0.14);
  }

  .aeonic-vs__compare-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.2rem;
    margin: 0;
    font-size: 1.4rem;
    color: rgba(var(--color-foreground), 0.55);
  }

  .aeonic-vs__compare-price {
    font-variant-numeric: tabular-nums;
    text-decoration: line-through;
    white-space: nowrap;
  }

  .aeonic-vs__compare-note {
    margin: 0.3rem 0 0;
    font-size: 1.2rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.42);
  }

  .aeonic-vs__savings {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    margin: 1.3rem 0 0;
    padding: 1rem 1.2rem;
    border-radius: 6px;
    background: rgba(46, 160, 77, 0.08);
    border: 1px solid rgba(46, 160, 77, 0.2);
    font-size: 1.4rem;
    line-height: 1.45;
    color: rgba(var(--color-foreground), 0.85);
  }

  .aeonic-vs__savings strong {
    font-weight: 700;
    color: rgb(var(--color-foreground));
  }

  .aeonic-vs__savings sup {
    font-size: 0.7em;
    line-height: 1;
  }

  .aeonic-vs__savings svg {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    margin-top: 0.25rem;
    color: #2ea04d;
  }

  .aeonic-vs__footnote {
    margin: 0.9rem 0 0;
    font-size: 1.15rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.45);
  }
{%- endstyle -%}
