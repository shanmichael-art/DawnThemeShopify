<div class="aeonic-contact color-{{ section.settings.color_scheme }} gradient">
  <div class="aeonic-contact__inner">
    {%- if section.settings.eyebrow != blank -%}
      <span class="aeonic-contact__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="aeonic-contact__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.intro != blank -%}
      <p class="aeonic-contact__intro">{{ section.settings.intro }}</p>
    {%- endif -%}

    <dl class="aeonic-contact__facts">
      {%- if section.settings.response_time != blank -%}
        <div class="aeonic-contact__fact">
          <dt>
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="8" cy="8" r="6.5"/>
              <polyline points="8 4.2 8 8 10.6 9.6"/>
            </svg>
            Response time
          </dt>
          <dd>{{ section.settings.response_time }}</dd>
        </div>
      {%- endif -%}

      {%- if section.settings.email != blank -%}
        <div class="aeonic-contact__fact">
          <dt>
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="1.2" y="3.2" width="13.6" height="9.6" rx="1.2"/>
              <path d="m1.6 4.2 6.4 4.6 6.4-4.6"/>
            </svg>
            Email
          </dt>
          <dd><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></dd>
        </div>
      {%- endif -%}

      {%- if section.settings.location != blank -%}
        <div class="aeonic-contact__fact">
          <dt>
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M8 14.5s5-4.2 5-8a5 5 0 0 0-10 0c0 3.8 5 8 5 8z"/>
              <circle cx="8" cy="6.4" r="1.9"/>
            </svg>
            Based in
          </dt>
          <dd>{{ section.settings.location }}</dd>
        </div>
      {%- endif -%}
    </dl>

    {%- if section.settings.prompts != blank -%}
      <div class="aeonic-contact__prompts">
        <p class="aeonic-contact__prompts-title">{{ section.settings.prompts_title }}</p>
        <div class="aeonic-contact__prompts-list">{{ section.settings.prompts }}</div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Contact Details",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Get in touch"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ask me anything before you buy."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Every message comes straight to me — not a support team, not a queue. If you want more detail on a guitar before spending real money on it, that's exactly what I'm here for."
    },
    {
      "type": "header",
      "content": "Contact facts"
    },
    {
      "type": "text",
      "id": "response_time",
      "label": "Response time",
      "default": "Usually within a few hours, always same day"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "info": "Make sure this inbox exists before publishing.",
      "default": "shan@aeonicfrets.com"
    },
    {
      "type": "text",
      "id": "location",
      "label": "Location",
      "default": "Spring Hill, Florida"
    },
    {
      "type": "header",
      "content": "What to ask"
    },
    {
      "type": "text",
      "id": "prompts_title",
      "label": "Prompts heading",
      "default": "Good things to ask about:"
    },
    {
      "type": "richtext",
      "id": "prompts",
      "label": "Prompts",
      "default": "<ul><li>More photos of a specific area — the back, the neck joint, a mark you spotted</li><li>A measurement: weight, neck profile, action, fret life</li><li>Anything in the condition notes you'd like clarified</li><li>Whether a guitar can legally ship to your country</li><li>Whether something similar is coming in soon</li></ul>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Contact Details"
    }
  ]
}
{% endschema %}

{%- style -%}
  .aeonic-contact {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .aeonic-contact {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .aeonic-contact__inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 var(--page-width-padding, 20px);
  }

  .aeonic-contact__eyebrow {
    display: block;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #e7cc87;
    margin-bottom: 1rem;
  }

  .aeonic-contact__heading {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.6rem, 4vw, 3.8rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: rgb(var(--color-foreground));
    margin: 0 0 1.6rem;
  }

  .aeonic-contact__intro {
    font-size: 1.6rem;
    line-height: 1.65;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0 0 3rem;
  }

  .aeonic-contact__facts {
    margin: 0 0 3rem;
    padding: 2rem 0;
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.1);
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  .aeonic-contact__fact {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem 1.6rem;
  }

  .aeonic-contact__fact dt {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex: 0 0 auto;
    min-width: 15rem;
    margin: 0;
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: rgba(var(--color-foreground), 0.5);
  }

  .aeonic-contact__fact dt svg {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    color: #e7cc87;
  }

  .aeonic-contact__fact dd {
    margin: 0;
    font-size: 1.5rem;
    line-height: 1.5;
    color: rgb(var(--color-foreground));
  }

  .aeonic-contact__fact dd a {
    color: #e7cc87;
    text-underline-offset: 3px;
  }

  .aeonic-contact__prompts-title {
    font-size: 1.4rem;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    margin: 0 0 0.8rem;
  }

  .aeonic-contact__prompts-list ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .aeonic-contact__prompts-list li {
    position: relative;
    padding: 0.35rem 0 0.35rem 1.8rem;
    font-size: 1.45rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.7);
  }

  .aeonic-contact__prompts-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: #e7cc87;
    font-weight: 600;
  }
{%- endstyle -%}
