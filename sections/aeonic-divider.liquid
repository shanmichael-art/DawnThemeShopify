<style>
  .aeonic-divider-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

<div class="aeonic-divider-section color-{{ section.settings.color_scheme }} gradient">
  <div class="aeonic-divider page-width">
    <div class="aeonic-divider__rule-wrap">
      <span class="aeonic-divider__line"></span>
      <span class="aeonic-divider__symbol" aria-hidden="true">{{ section.settings.symbol }}</span>
      <span class="aeonic-divider__line"></span>
    </div>
    {%- if section.settings.text != blank -%}
      <p class="aeonic-divider__text">{{ section.settings.text | escape }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Section Divider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "symbol",
      "label": "Center symbol",
      "default": "◆"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Optional text below rule",
      "info": "Keep it short. Use it like a caption or a one-line brand statement.",
      "default": "Every guitar here has been played by me first."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Section Divider"
    }
  ]
}
{% endschema %}
