<style>
  .aeonic-condition-explainer {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .aeonic-condition-explainer {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>

<div class="aeonic-condition-explainer color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="aeonic-condition-explainer__header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <h1 class="aeonic-condition-explainer__heading">{{ section.settings.heading | escape }}</h1>
        {%- if section.settings.subheading != blank -%}
          <h2 class="aeonic-condition-explainer__subheading">{{ section.settings.subheading | escape }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="aeonic-condition-grades{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">

      <div class="aeonic-condition-grade aeonic-condition-grade--excellent">
        <div class="aeonic-condition-grade__badge">
          <span class="aeonic-condition-grade__dot"></span>
          <span class="aeonic-condition-grade__name">{{ section.settings.grade_1_name | default: 'Excellent' }}</span>
        </div>
        <p class="aeonic-condition-grade__description">{{ section.settings.grade_1_desc | default: 'Looks and plays like new. May have been barely played — cosmetically near-flawless with no structural issues. Full setup done, intonation dialed, action set to preference.' }}</p>
      </div>

      <div class="aeonic-condition-grade aeonic-condition-grade--very-good">
        <div class="aeonic-condition-grade__badge">
          <span class="aeonic-condition-grade__dot"></span>
          <span class="aeonic-condition-grade__name">{{ section.settings.grade_2_name | default: 'Very Good' }}</span>
        </div>
        <p class="aeonic-condition-grade__description">{{ section.settings.grade_2_desc | default: 'Shows light play wear — minor pick marks, light buckle rash, or small finish scuffs. Nothing structural. Fully playable and set up. All cosmetic notes are documented in the listing.' }}</p>
      </div>

      <div class="aeonic-condition-grade aeonic-condition-grade--good">
        <div class="aeonic-condition-grade__badge">
          <span class="aeonic-condition-grade__dot"></span>
          <span class="aeonic-condition-grade__name">{{ section.settings.grade_3_name | default: 'Good' }}</span>
        </div>
        <p class="aeonic-condition-grade__description">{{ section.settings.grade_3_desc | default: 'Has visible character from real use. Nothing hidden — every mark is photographed and noted. Still fully functional with a proper setup. Priced to reflect its honest condition.' }}</p>
      </div>

    </div>

    {%- if section.settings.footnote != blank -%}
      <p class="aeonic-condition-explainer__footnote{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.footnote | escape }}
      </p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Condition Grade Explainer",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How We Grade Our Guitars"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every listing includes an honest condition grade and full notes. No surprises when the case opens."
    },
    {
      "type": "header",
      "content": "Grade 1 — Excellent"
    },
    {
      "type": "text",
      "id": "grade_1_name",
      "label": "Grade name",
      "default": "Excellent"
    },
    {
      "type": "textarea",
      "id": "grade_1_desc",
      "label": "Description",
      "default": "Looks and plays like new. May have been barely played — cosmetically near-flawless with no structural issues. Full setup done, intonation dialed, action set to preference."
    },
    {
      "type": "header",
      "content": "Grade 2 — Very Good"
    },
    {
      "type": "text",
      "id": "grade_2_name",
      "label": "Grade name",
      "default": "Very Good"
    },
    {
      "type": "textarea",
      "id": "grade_2_desc",
      "label": "Description",
      "default": "Shows light play wear — minor pick marks, light buckle rash, or small finish scuffs. Nothing structural. Fully playable and set up. All cosmetic notes are documented in the listing."
    },
    {
      "type": "header",
      "content": "Grade 3 — Good"
    },
    {
      "type": "text",
      "id": "grade_3_name",
      "label": "Grade name",
      "default": "Good"
    },
    {
      "type": "textarea",
      "id": "grade_3_desc",
      "label": "Description",
      "default": "Has visible character from real use. Nothing hidden — every mark is photographed and noted. Still fully functional with a proper setup. Priced to reflect its honest condition."
    },
    {
      "type": "text",
      "id": "footnote",
      "label": "Footnote",
      "default": "All guitars ship fully insured. Condition notes and photos are included in every listing — no guessing."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Condition Grade Explainer"
    }
  ]
}
{% endschema %}
