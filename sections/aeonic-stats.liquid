<style>
  .aeonic-stats-section {
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>

<div class="aeonic-stats-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="aeonic-stats">
    {%- for i in (1..4) -%}
      {%- liquid
        assign number_key = 'stat_' | append: i | append: '_number'
        assign label_key  = 'stat_' | append: i | append: '_label'
        assign stat_number = section.settings[number_key]
        assign stat_label  = section.settings[label_key]
      -%}
      {%- if stat_number != blank or stat_label != blank -%}
        <div class="aeonic-stats__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}style="--animation-order: {{ forloop.index }};"{% endif %}>
          {%- if stat_number != blank -%}
            <span class="aeonic-stats__number">{{ stat_number }}</span>
          {%- endif -%}
          {%- if stat_label != blank -%}
            <span class="aeonic-stats__label">{{ stat_label }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Trust Stats Bar",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    },
    {
      "type": "header",
      "content": "Stat 1"
    },
    {
      "type": "text",
      "id": "stat_1_number",
      "label": "Number / Value",
      "default": "500+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Label",
      "default": "Guitars Sold"
    },
    {
      "type": "header",
      "content": "Stat 2"
    },
    {
      "type": "text",
      "id": "stat_2_number",
      "label": "Number / Value",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Label",
      "default": "Hand-Inspected & Set Up"
    },
    {
      "type": "header",
      "content": "Stat 3"
    },
    {
      "type": "text",
      "id": "stat_3_number",
      "label": "Number / Value",
      "default": "5★"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Label",
      "default": "Rated on Reverb"
    },
    {
      "type": "header",
      "content": "Stat 4"
    },
    {
      "type": "text",
      "id": "stat_4_number",
      "label": "Number / Value",
      "default": "24hrs"
    },
    {
      "type": "text",
      "id": "stat_4_label",
      "label": "Label",
      "default": "Avg. Ship Time"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Trust Stats Bar"
    }
  ]
}
{% endschema %}
