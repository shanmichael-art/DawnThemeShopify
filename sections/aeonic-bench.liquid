<style>
  .aeonic-bench-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .aeonic-bench {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 var(--page-width-padding, 20px);
  }

  .aeonic-bench__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 3.5rem;
  }

  .aeonic-bench__eyebrow {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #e7cc87;
    margin-bottom: 0.8rem;
  }

  .aeonic-bench__heading {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0 0 0.8rem;
    color: rgb(var(--color-foreground));
  }

  .aeonic-bench__subheading {
    font-size: 0.95rem;
    color: rgba(var(--color-foreground), 0.6);
    line-height: 1.55;
    margin: 0;
  }

  .aeonic-bench__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 3rem;
  }

  .aeonic-bench__card {
    border: 1px solid rgba(var(--color-foreground), 0.1);
    border-radius: 6px;
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.02);
    transition: border-color 0.2s ease, transform 0.25s ease;
  }

  .aeonic-bench__card:hover {
    border-color: rgba(231, 204, 135, 0.35);
    transform: translateY(-3px);
  }

  .aeonic-bench__card-image {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .aeonic-bench__card-image-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: rgba(var(--color-foreground), 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(var(--color-foreground), 0.2);
    font-size: 3rem;
  }

  .aeonic-bench__card-body {
    padding: 20px 22px 22px;
  }

  .aeonic-bench__card-status {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 2px;
    margin-bottom: 10px;
  }

  .aeonic-bench__card-status--in-progress {
    background: rgba(231, 204, 135, 0.15);
    color: #e7cc87;
    border: 1px solid rgba(231, 204, 135, 0.3);
  }

  .aeonic-bench__card-status--coming-soon {
    background: rgba(var(--color-foreground), 0.06);
    color: rgba(var(--color-foreground), 0.5);
    border: 1px solid rgba(var(--color-foreground), 0.12);
  }

  .aeonic-bench__card-name {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: rgb(var(--color-foreground));
    margin: 0 0 6px;
    line-height: 1.3;
  }

  .aeonic-bench__card-work {
    font-size: 0.85rem;
    color: rgba(var(--color-foreground), 0.6);
    line-height: 1.5;
    margin: 0 0 14px;
  }

  .aeonic-bench__card-eta {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.4);
  }

  .aeonic-bench__notify {
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
    padding-top: 2.5rem;
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
  }

  .aeonic-bench__notify-label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(var(--color-foreground), 0.65);
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .aeonic-bench__notify-form {
    display: flex;
    gap: 8px;
    max-width: 380px;
    margin: 0 auto;
  }

  .aeonic-bench__notify-input {
    flex: 1;
    padding: 11px 14px;
    font-size: 0.88rem;
    border: 1px solid rgba(var(--color-foreground), 0.2);
    border-radius: var(--inputs-radius, 4px);
    background: rgba(var(--color-foreground), 0.03);
    color: rgb(var(--color-foreground));
    outline: none;
    transition: border-color 0.2s ease;
  }

  .aeonic-bench__notify-input:focus {
    border-color: #e7cc87;
  }

  .aeonic-bench__notify-input::placeholder {
    color: rgba(var(--color-foreground), 0.35);
  }

  .aeonic-bench__notify-btn {
    padding: 11px 20px;
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    border: none;
    border-radius: var(--buttons-radius, 2px);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s ease;
  }

  .aeonic-bench__notify-btn:hover {
    opacity: 0.85;
  }

  @media screen and (max-width: 989px) {
    .aeonic-bench__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .aeonic-bench__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .aeonic-bench__notify-form {
      flex-direction: column;
    }

    .aeonic-bench__notify-btn {
      width: 100%;
      padding: 13px;
    }
  }
</style>

<div class="aeonic-bench-section color-{{ section.settings.color_scheme }} gradient">
  <div class="aeonic-bench">
    <div class="aeonic-bench__header">
      <span class="aeonic-bench__eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="aeonic-bench__heading">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="aeonic-bench__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="aeonic-bench__grid">
        {%- for block in section.blocks -%}
          <div class="aeonic-bench__card" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.guitar_name | escape }}"
                class="aeonic-bench__card-image"
                loading="lazy"
                width="800"
                height="600"
              >
            {%- else -%}
              <div class="aeonic-bench__card-image-placeholder" aria-hidden="true">♩</div>
            {%- endif -%}
            <div class="aeonic-bench__card-body">
              {%- if block.settings.status == 'in_progress' -%}
                <span class="aeonic-bench__card-status aeonic-bench__card-status--in-progress">On the Bench</span>
              {%- else -%}
                <span class="aeonic-bench__card-status aeonic-bench__card-status--coming-soon">Coming Soon</span>
              {%- endif -%}
              <p class="aeonic-bench__card-name">{{ block.settings.guitar_name | escape }}</p>
              {%- if block.settings.work_description != blank -%}
                <p class="aeonic-bench__card-work">{{ block.settings.work_description | escape }}</p>
              {%- endif -%}
              {%- if block.settings.eta != blank -%}
                <span class="aeonic-bench__card-eta">{{ block.settings.eta | escape }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_notify -%}
      <div class="aeonic-bench__notify">
        <span class="aeonic-bench__notify-label">{{ section.settings.notify_label | escape }}</span>
        {% form 'customer', id: 'aeonic-bench-notify-form' %}
          <div class="aeonic-bench__notify-form">
            <input
              type="email"
              name="contact[email]"
              id="aeonic-bench-email"
              class="aeonic-bench__notify-input"
              placeholder="{{ section.settings.notify_placeholder | escape }}"
              required
              autocomplete="email"
            >
            <input type="hidden" name="contact[tags]" value="bench-notify">
            <button type="submit" class="aeonic-bench__notify-btn">
              {{- section.settings.notify_button | escape -}}
            </button>
          </div>
        {% endform %}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "The Bench",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "What I'm Working On"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Bench"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "These guitars aren't listed yet. Setup is in progress — check back soon, or get notified when they drop."
    },
    {
      "type": "header",
      "content": "Notify Me signup"
    },
    {
      "type": "checkbox",
      "id": "show_notify",
      "label": "Show email signup",
      "default": true
    },
    {
      "type": "text",
      "id": "notify_label",
      "label": "Notify form label",
      "default": "Want a heads-up when something drops? Leave your email."
    },
    {
      "type": "text",
      "id": "notify_placeholder",
      "label": "Input placeholder",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "notify_button",
      "label": "Button label",
      "default": "Notify Me"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Top padding",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Bottom padding",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "guitar",
      "name": "Guitar",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Guitar photo"
        },
        {
          "type": "text",
          "id": "guitar_name",
          "label": "Guitar name",
          "default": "1972 Gibson ES-335"
        },
        {
          "type": "select",
          "id": "status",
          "label": "Status",
          "options": [
            { "value": "in_progress", "label": "On the Bench" },
            { "value": "coming_soon", "label": "Coming Soon" }
          ],
          "default": "in_progress"
        },
        {
          "type": "text",
          "id": "work_description",
          "label": "Work being done",
          "default": "Full cleaning, fret level, intonation set, fresh strings."
        },
        {
          "type": "text",
          "id": "eta",
          "label": "ETA / Timeline",
          "default": "Est. listing: this week"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "The Bench",
      "blocks": [
        {
          "type": "guitar",
          "settings": {
            "guitar_name": "Coming Soon — Watch This Space",
            "status": "coming_soon",
            "work_description": "Currently being cleaned, set up, and played. I'll add details before it lists.",
            "eta": "Est. listing: soon"
          }
        }
      ]
    }
  ]
}
{% endschema %}
